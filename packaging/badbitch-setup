#!/usr/bin/env bash
# badbitch-setup — finish a badbitch install: Ollama + model + optional OSINT CLIs + config.
# Safe to re-run; every step is idempotent and best-effort (a failure prints a hint, never
# aborts the rest). Run as your normal user, NOT root, so the config lands in your HOME.
#
#   badbitch-setup                 # full setup with the default model
#   BADBITCH_MODEL=... badbitch-setup   # override the model to pull / configure
#   BADBITCH_SKIP_MODEL=1 badbitch-setup   # skip the (large) model pull
set -uo pipefail

# Default is a 14B abliterated model that fits a 12 GB GPU at ~100% GPU (no CPU offload).
# Override with BADBITCH_MODEL=... for a bigger model if you have the VRAM.
MODEL="${BADBITCH_MODEL:-richardyoung/qwen3-14b-abliterated:latest}"

say()  { printf '\033[1;35m[badbitch-setup]\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[badbitch-setup][warn]\033[0m %s\n' "$*" >&2; }

if [ "$(id -u)" = "0" ]; then
  warn "running as root — config will be written to /root. Re-run as your normal user for a per-user config."
fi

# 1. Ollama -------------------------------------------------------------------
if ! command -v ollama >/dev/null 2>&1; then
  say "installing Ollama (official script)…"
  if ! curl -fsSL https://ollama.com/install.sh | sh; then
    warn "Ollama install failed. Install it manually from https://ollama.com/download then re-run."
  fi
fi

# Make sure a server is reachable; start one in the background if not.
if command -v ollama >/dev/null 2>&1; then
  if ! curl -fsS http://127.0.0.1:11434/api/tags >/dev/null 2>&1; then
    say "starting 'ollama serve' in the background…"
    (ollama serve >/tmp/badbitch-ollama.log 2>&1 &) || true
    for _ in 1 2 3 4 5 6; do
      curl -fsS http://127.0.0.1:11434/api/tags >/dev/null 2>&1 && break
      sleep 2
    done
  fi
fi

# 2. Model --------------------------------------------------------------------
if [ "${BADBITCH_SKIP_MODEL:-0}" = "1" ]; then
  say "skipping model pull (BADBITCH_SKIP_MODEL=1). Model configured as: $MODEL"
elif command -v ollama >/dev/null 2>&1; then
  say "pulling model: $MODEL  (this can be several GB — go get a coffee)…"
  ollama pull "$MODEL" || warn "model pull failed; pull it later with: ollama pull $MODEL"
else
  warn "Ollama not available — skipping model pull. After installing it: ollama pull $MODEL"
fi

# 3. Optional OSINT CLIs (not apt-packaged) -----------------------------------
if command -v pipx >/dev/null 2>&1; then
  say "installing optional OSINT CLIs via pipx (sherlock, holehe, theHarvester)…"
  pipx install sherlock-project >/dev/null 2>&1 || warn "pipx install sherlock-project failed"
  pipx install holehe          >/dev/null 2>&1 || warn "pipx install holehe failed"
  pipx install theHarvester    >/dev/null 2>&1 || warn "pipx install theHarvester failed"
else
  warn "pipx not found — skipping sherlock/holehe/theHarvester. Install pipx then: pipx install sherlock-project holehe theHarvester"
fi
say "phoneinfoga is optional and not on apt — see https://sundowndev.github.io/phoneinfoga/ if you need it."

# 4. Config -------------------------------------------------------------------
CFG="${HOME}/.config/badbitch-rs/config.ini"
if [ ! -f "$CFG" ]; then
  badbitch --init-config >/dev/null 2>&1 || warn "could not write $CFG"
fi
if [ -f "$CFG" ]; then
  # Point the config at the model we just pulled. Match any spacing around '=' —
  # config files may be written "name = x", "name =x", or "name=x".
  if grep -qE '^[[:space:]]*name[[:space:]]*=' "$CFG"; then
    sed -i "s|^[[:space:]]*name[[:space:]]*=.*|name = ${MODEL}|" "$CFG" 2>/dev/null || true
  else
    # No [model] name line at all — add one under [model] (or append a section).
    if grep -qE '^\[model\]' "$CFG"; then
      sed -i "s|^\[model\]|[model]\nname = ${MODEL}|" "$CFG" 2>/dev/null || true
    else
      printf '\n[model]\nname = %s\n' "$MODEL" >> "$CFG"
    fi
  fi
  say "config: $CFG  ->  model set to ${MODEL}"
  say "  (set num_ctx for your GPU, fill [api_keys] with any keys you have)"
fi

# 5. SearXNG note (needed by web_search; not apt-installable cleanly) ----------
say "web_search needs a local SearXNG at http://127.0.0.1:8888 — easiest via Docker:"
say "  docker run -d --name searxng -p 8888:8080 searxng/searxng"

say "done. Try:  badbitch \"<a target>\"   or just  badbitch  for the REPL."
